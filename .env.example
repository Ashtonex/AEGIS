# Environment Configuration

# === Backend (FastAPI) ===
ENVIRONMENT=development
DEBUG=false
SECRET_KEY=replace-with-32-plus-character-random-secret
ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Connections
# (Required for SQLAlchemy async engine)
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase Client
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=[YOUR-ANON-KEY]
SUPABASE_SERVICE_KEY=[YOUR-SERVICE-ROLE-KEY]

# JWT Verification Control (Local Decoders)
JWT_SECRET_KEY=replace-with-32-plus-character-rotation-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=aegis-auth
JWT_AUDIENCE=authenticated
AUTH_TOKEN_ISSUER=supabase
AUTH_TOKEN_AUDIENCE=authenticated
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_KEY_ROTATION_GRACE_DAYS=7

# Caching & Background Workers (Redis / Arq)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0
BACKGROUND_JOBS_ENABLED=false
WORKER_QUEUE_NAME=aegis:jobs
WORKER_JOB_TIMEOUT_SECONDS=300
WORKER_JOB_MAX_TRIES=3

# Logging and Document Controls
LOG_LEVEL=INFO
LOG_JSON=false
FILE_STORAGE_MAX_BYTES=26214400
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.docx,.xlsx,.xls,.csv,.png,.jpg,.jpeg
GENERATED_DOCUMENT_DIR=generated
REPORT_OUTPUT_DIR=generated/reports
REPORT_TEMPLATE_DIR=templates/reports
EXTERNAL_API_TIMEOUT_SECONDS=30
NOTIFICATION_WEBHOOK_URL=

# WhatsApp Business Platform / Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_APP_SECRET=

# Twilio Programmable Voice
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WEBHOOK_BASE_URL=

# === Frontend (Next.js) ===
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR-ANON-KEY]
NEXT_PUBLIC_API_URL=http://localhost:8000
